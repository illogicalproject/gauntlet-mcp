# Multi-Model Red-Team Kit — environment config
# Copy this to pal-mcp-server/.env after running ./install.sh
#
# Red-teaming works best with at least TWO providers from different vendors,
# so models with different training and blind spots check each other.
# Fill in the keys you have; leave the rest blank.

# --- Native provider APIs (recommended for red-teaming: distinct architectures) ---

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude as a callable model, in addition to your CLI) — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# X.AI Grok — https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# --- OR a single unified gateway (don't mix with the native keys above) ---
# OpenRouter — https://openrouter.ai/  (one key, many models)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Local / on-device models (free extra voice in the debate) ---
# Ollama / LM Studio / vLLM, OpenAI-compatible endpoint
# CUSTOM_API_URL=http://localhost:11434/v1
# CUSTOM_API_KEY=
# CUSTOM_MODEL_NAME=llama3.2

# --- Behavior ---
# 'auto' lets your CLI pick the best model per sub-task. For strict
# comparison runs you'll usually name models explicitly in the prompt instead.
DEFAULT_MODEL=auto

# Thinking budget for the thinkdeep tool (minimal|low|medium|high|max)
# medium is a good default; raise for hard adversarial problems.
DEFAULT_THINKING_MODE_THINKDEEP=medium
